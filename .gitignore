# Python virtual environment
/*/.venv/
/*/*/.venv/

postgres_data/*
invoices_data/*
backups/*

# Template custom con logo e dati personali (vivono solo sul server di produzione)
custom_template/*.docx

.env

# Config locale di deploy (host/utente/path del server) — mai committare
.claude/*.local.env
.claude/settings.local.json

# Python
*.pyc
__pycache__/
.pytest_cache/ # Se usi pytest, anche questa cartella è generata automaticamente
.mypy_cache/   # Se usi mypy per il type checking

# STS certificates (never commit real certs — eccezione: CA pubblica di test)
certs/*.pem
certs/*.crt
certs/*.key
# Solo i cert privati/produzione: escludere i CA cert pubblici del kit
certs/sts_cert.pem
