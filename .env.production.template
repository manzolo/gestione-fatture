# =============================================================================
# TEMPLATE VARIABILI DI PRODUZIONE — invoice-app
# =============================================================================
# Copia questo file in .env sul server di produzione e compila tutti i campi
# marcati con <SOSTITUIRE>. Non committare mai il file .env compilato.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=backend_db
POSTGRES_USER=<SOSTITUIRE: utente DB>
POSTGRES_PASSWORD=<SOSTITUIRE: password DB sicura>

PGADMIN_DEFAULT_EMAIL=<SOSTITUIRE: email admin PgAdmin>
PGADMIN_DEFAULT_PASSWORD=<SOSTITUIRE: password admin PgAdmin>
PGADMIN_PORT=80
PGADMIN_HOST_PORT=8001

# --- Rete interna Docker ---
POSTGRES_HOST=invoice_postgres_db
BACKEND_HOST=invoice_backend
BACKEND_PORT=8000
FRONTEND_EXTERNAL_PORT=8080

GOTENBERG_HOST=invoice_gotenberg
GOTENBERG_PORT=3000

# --- Flask ---
SECRET_KEY=<SOSTITUIRE: stringa random lunga, es. openssl rand -hex 32>
APP_DEBUG=False

# =============================================================================
# === STS (Sistema Tessera Sanitaria) — PRODUZIONE ===
# =============================================================================
#
# COME OTTENERE LE CREDENZIALI DI PRODUZIONE:
#
# 1. Accedi al portale STS: https://sistemats1.sanita.finanze.it/
#    (sezione "Accesso Professionisti" con SPID/CIE o CNS)
#
# 2. Nel portale STS recupera:
#    - Username: il tuo Codice Fiscale (CF professionista)
#    - Password: la password scelta al momento della registrazione
#    - Pincode: il pincode assegnato dal sistema
#
# 3. Per ottenere PINCODE_ENCRYPTED e CF_PROPRIETARIO_ENCRYPTED:
#    Usa il tool di cifratura incluso nel kit ufficiale STS:
#      kit730P_ver_20240214/certificatiFirma/
#    Oppure usa il tool online del portale STS per cifrare i valori
#    con la chiave pubblica RSA del sistema.
#    I valori cifrati cambiano ad ogni login: rigenera quando cambi password.
#
# 4. STS_CERTIFICATE_PATH:
#    Il file certs/sts_cert.pem (SanitelCF.cer dal kit) è lo STESSO
#    sia in test che in produzione — è il certificato pubblico di
#    Agenzia delle Entrate per cifrare il CF del paziente.
#    Non serve scaricarne un altro.
#
# 5. STS_CA_BUNDLE:
#    In produzione NON serve (il server usa una CA pubblica standard).
#    Lascia vuoto o rimuovi la variabile.
#
# =============================================================================

STS_ENVIRONMENT=production

# Credenziali professionista (ottenute dal portale STS)
STS_USERNAME=<SOSTITUIRE: Codice Fiscale del professionista>
STS_PASSWORD=<SOSTITUIRE: password portale STS>
STS_PINCODE_ENCRYPTED=<SOSTITUIRE: pincode cifrato RSA dal portale STS>
STS_CF_PROPRIETARIO_ENCRYPTED=<SOSTITUIRE: CF proprietario cifrato RSA dal portale STS>

# Dati professionista
STS_PARTITA_IVA=<SOSTITUIRE: Partita IVA del professionista>
STS_DISPOSITIVO=1

# Certificato SanitelCF per cifratura CF paziente
# NOTA: certs/sts_cert.pem è già presente (copiato da kit730P_ver_20240214/SanitelCF.cer)
#       Lo stesso certificato vale per test e produzione.
STS_CERTIFICATE_PATH=/app/certs/sts_cert.pem

# CA bundle: in produzione il server STS usa CA pubblica standard → lascia vuoto
STS_CA_BUNDLE=

# In produzione DEVE essere true (verifica TLS abilitata)
STS_SSL_VERIFY=true
