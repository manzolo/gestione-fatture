# =============================================================================
# TEMPLATE VARIABILI DI PRODUZIONE — invoice-app
# =============================================================================
# Copia questo file in .env sul server di produzione e compila tutti i campi
# marcati con <SOSTITUIRE>. Non committare mai il file .env compilato.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=backend_db
POSTGRES_USER=<SOSTITUIRE: utente DB>
POSTGRES_PASSWORD=<SOSTITUIRE: password DB sicura>

PGADMIN_DEFAULT_EMAIL=<SOSTITUIRE: email admin PgAdmin>
PGADMIN_DEFAULT_PASSWORD=<SOSTITUIRE: password admin PgAdmin>
PGADMIN_PORT=80
PGADMIN_HOST_PORT=8001

# --- Rete interna Docker ---
POSTGRES_HOST=invoice_postgres_db
BACKEND_HOST=invoice_backend
BACKEND_PORT=8000
FRONTEND_EXTERNAL_PORT=8080

GOTENBERG_HOST=invoice_gotenberg
GOTENBERG_PORT=3000

# --- Flask ---
SECRET_KEY=<SOSTITUIRE: stringa random lunga, es. openssl rand -hex 32>
APP_DEBUG=False

# =============================================================================
# === STS (Sistema Tessera Sanitaria) — PRODUZIONE ===
# =============================================================================
#
# COME OTTENERE LE CREDENZIALI DI PRODUZIONE:
#
# STEP 1 — Accedi al portale STS:
#   https://sistemats1.sanita.finanze.it/
#   (sezione "Accesso Professionisti" con SPID/CIE o CNS)
#   Recupera: Username (CF professionista), Password, Pincode.
#
# STEP 2 — Copia il certificato sul server di produzione:
#   scp certs/sts_cert.pem utente@server:/percorso/invoice-app/certs/sts_cert.pem
#   (è già nel repo locale, gitignored — va copiato manualmente)
#
# STEP 3 — Genera i valori cifrati per PINCODE_ENCRYPTED e CF_PROPRIETARIO_ENCRYPTED:
#
#   Sul server (o in locale se hai Python e il repo):
#
#     python3 scripts/sts_encrypt.py \
#         --pincode <PINCODE_IN_CHIARO> \
#         --cf <TUO_CODICE_FISCALE>
#
#   Lo script cifra entrambi i valori con RSA PKCS#1 v1.5 usando certs/sts_cert.pem
#   e stampa le righe pronte da incollare in questo file.
#
#   Esempio output:
#     STS_PINCODE_ENCRYPTED=AbCdEf1234...==
#     STS_CF_PROPRIETARIO_ENCRYPTED=XyZaBc5678...==
#
#   NOTA: RSA PKCS#1 v1.5 è non-deterministico — ogni esecuzione produce
#   valori diversi ma tutti ugualmente validi. Non occorre memorizzarli:
#   riesegui lo script ogni volta che devi aggiornare le credenziali.
#
# STEP 4 — STS_CA_BUNDLE:
#   In produzione NON serve (il server usa CA pubblica standard) → lascia vuoto.
#
# =============================================================================

STS_ENVIRONMENT=production

# Credenziali professionista (ottenute dal portale STS)
STS_USERNAME=<SOSTITUIRE: Codice Fiscale del professionista>
STS_PASSWORD=<SOSTITUIRE: password portale STS>
# Genera questi due valori con: python3 scripts/sts_encrypt.py --pincode <PIN> --cf <CF>
STS_PINCODE_ENCRYPTED=<SOSTITUIRE: output di sts_encrypt.py>
STS_CF_PROPRIETARIO_ENCRYPTED=<SOSTITUIRE: output di sts_encrypt.py>

# Dati professionista
STS_PARTITA_IVA=<SOSTITUIRE: Partita IVA del professionista>
STS_DISPOSITIVO=1

# Certificato SanitelCF per cifratura CF paziente
# NOTA: certs/sts_cert.pem è già presente (copiato da kit730P_ver_20240214/SanitelCF.cer)
#       Lo stesso certificato vale per test e produzione.
STS_CERTIFICATE_PATH=/app/certs/sts_cert.pem

# CA bundle: in produzione il server STS usa CA pubblica standard → lascia vuoto
STS_CA_BUNDLE=

# In produzione DEVE essere true (verifica TLS abilitata)
STS_SSL_VERIFY=true
