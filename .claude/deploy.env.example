# Template per la config di deploy usata da /bump.
# Copia questo file in `.claude/deploy.local.env` e compila con i valori reali.
# Il file .local.env è git-ignored: i dati personali (host, utente, path) NON finiscono nel repo.
DEPLOY_HOST=your-server-host       # es. alias SSH in ~/.ssh/config
DEPLOY_USER=your-ssh-user
DEPLOY_PATH=/path/to/stack/on/server
